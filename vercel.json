{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mandarinforge/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/mandarinforge/server/server.mjs"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs22.x"
    }
  }
}
